# FTP upload (marquee.html + matchupcard.html) – optional; if set, both are uploaded after saving
FTP_HOST=192.250.231.32
FTP_USER=streamadmin
FTP_PASSWORD=your_password
# CRITICAL: Must be the folder your WEB SERVER serves (document root). e.g. wwwroot, public_html, www, htdocs.
FTP_REMOTE_DIR=wwwroot
# Base URL for OBS browser sources; marquee and matchup card get ?v=xxx cache bust on each update.
# NEXT_PUBLIC_STREAM_OVERLAY_BASE_URL=http://stream.poolhub.us
# MARQUEE_PUBLIC_URL=http://stream.poolhub.us
# MATCHUPCARD_PUBLIC_URL=http://stream.poolhub.us
# MATCHUPCARD_URL_PATH=matchupcard.html

# App-hosted overlays (faster than GitHub – no upload delay). Set your app’s public URL when deployed.
# OBS uses https://YOUR_APP/api/overlay/marquee and /api/overlay/matchup-card. Takes precedence over GitHub.
# OVERLAY_PUBLIC_BASE_URL=https://your-app.vercel.app
# Or: NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# GitHub upload – optional; used when OVERLAY_PUBLIC_BASE_URL is not set.
# Create a Personal Access Token at https://github.com/settings/tokens with "repo" scope.
# GITHUB_TOKEN=ghp_xxxx
# GITHUB_REPO=owner/repo-name
# GITHUB_BRANCH=main

# OBS WebSocket – optional; app connects on load. Enable "WebSocket server" in OBS Tools and set a password.
# NEXT_PUBLIC_OBS_WS_URL=ws://192.168.1.50:4455
# NEXT_PUBLIC_OBS_WS_PASSWORD=your_obs_websocket_password
