# FTP upload (marquee.html) – optional; if set, overlay is uploaded after saving locally
FTP_HOST=192.250.231.32
FTP_USER=streamadmin
FTP_PASSWORD=your_password
# Remote directory = web root so the file is served (e.g. public_html, www, htdocs). Required to avoid 404.
FTP_REMOTE_DIR=public_html
# Optional: base URL for the marquee (shown in dashboard). Defaults to http://FTP_HOST.
# MARQUEE_PUBLIC_URL=http://192.250.231.32
# Optional: URL path (default marquee.html). Use if your server serves from a subpath.
# MARQUEE_URL_PATH=marquee.html

# GitHub upload – optional; uploads marquee.html to your repo and Marquee Path shows GitHub Pages URL.
# Create a Personal Access Token at https://github.com/settings/tokens with "repo" scope.
# GITHUB_TOKEN=ghp_xxxx
# GITHUB_REPO=owner/repo-name
# GITHUB_BRANCH=main

# OBS WebSocket – optional; app connects on load. Enable "WebSocket server" in OBS Tools and set a password.
# NEXT_PUBLIC_OBS_WS_URL=ws://192.168.1.50:4455
# NEXT_PUBLIC_OBS_WS_PASSWORD=your_obs_websocket_password
